{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Docs",
  "description": "Bidirectional AI code governance. Protect secrets going out, validate code coming in.",

  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },

  "logo": {
    "light": "/logo/takumo-dark.svg",
    "dark": "/logo/takumo-light.svg",
    "href": "/"
  },

  "favicon": "/logo/favicon.svg",

  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "themes": {
        "light": "github-light",
        "dark": "github-dark"
      }
    },
    "anchors": "buttons",
    "rounded": "default",
    "icons": {
      "library": "lucide"
    }
  },

  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },

  "appearance": {
    "default": "dark",
    "strict": true
  },

  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#FFFFFF",
      "dark": "#000000"
    }
  },

  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Takumo Cloud",
      "href": "https://cloud.takumo.io/dashboard"
    }
  },

  "anchors": [
    {
      "anchor": "Takumo Cloud",
      "icon": "grid-2x2",
      "href": "https://cloud.takumo.io/dashboard"
    },
    {
      "anchor": "GitHub",
      "icon": "github",
      "href": "https://github.com/SirTingling/takumo"
    }
  ],

  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "quickstart",
              "installation",
              "authentication",
              "first-request"
            ]
          },
          {
            "group": "Concepts",
            "icon": "lightbulb",
            "pages": [
              "concepts/how-it-works",
              "concepts/aegis-shield",
              "concepts/sentinel",
              "concepts/security",
              "concepts/policies"
            ]
          },
          {
            "group": "Reference",
            "icon": "bookmark",
            "pages": [
              "patterns/supported",
              "reference/plan-comparison",
              "reference/error-codes",
              "reference/faq",
              "reference/troubleshooting",
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "Dashboard",
        "icon": "grid-2x2",
        "groups": [
          {
            "group": "Guide",
            "icon": "book-open",
            "pages": [
              "dashboard/overview",
              "dashboard/api-keys",
              "dashboard/fleet",
              "dashboard/members",
              "dashboard/audit-log",
              "dashboard/security",
              "dashboard/billing",
              "dashboard/settings"
            ]
          }
        ]
      },
      {
        "tab": "Deployment",
        "icon": "cloud",
        "groups": [
          {
            "group": "Guides",
            "icon": "server",
            "pages": [
              "deployment/overview",
              "deployment/saas",
              "deployment/onprem",
              "deployment/configuration",
              "deployment/monitoring"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "icon": "terminal",
        "groups": [
          {
            "group": "Commands",
            "pages": [
              "cli/overview",
              "cli/scan",
              "cli/tokenize",
              "cli/shield"
            ]
          }
        ]
      },
      {
        "tab": "AI Tools",
        "icon": "puzzle",
        "groups": [
          {
            "group": "Integrations",
            "pages": [
              "ai-tools/overview",
              "ai-tools/cursor",
              "ai-tools/copilot",
              "ai-tools/continue",
              "ai-tools/windsurf",
              "ai-tools/claude-code",
              "ai-tools/generic"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "icon": "code",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "api/overview",
              "api/authentication",
              "api/create-session",
              "api/tokenize",
              "api/rehydrate",
              "api/errors",
              "api/rate-limits",
              "api/webhooks"
            ]
          }
        ]
      }
    ]
  },

  "footer": {
    "socials": {
      "github": "https://github.com/SirTingling/takumo"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Aegis Shield", "href": "/concepts/aegis-shield" },
          { "label": "Sentinel", "href": "/concepts/sentinel" },
          { "label": "Pricing", "href": "/reference/plan-comparison" },
          { "label": "Changelog", "href": "/changelog" }
        ]
      },
      {
        "header": "Resources",
        "items": [
          { "label": "Documentation", "href": "/introduction" },
          { "label": "API Reference", "href": "/api/overview" },
          { "label": "Dashboard", "href": "https://cloud.takumo.io/dashboard" }
        ]
      }
    ]
  },

  "search": {
    "prompt": "Search docs..."
  },

  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "cursor"]
  }
}
