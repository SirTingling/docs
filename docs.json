{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Docs",
  "description": "Bidirectional AI code governance. Protect secrets going out, validate code coming in.",

  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },

  "logo": {
    "light": "/logo/takumo-dark.svg",
    "dark": "/logo/takumo-light.svg",
    "href": "/"
  },

  "favicon": "/logo/favicon.svg",

  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "themes": {
        "light": "github-light",
        "dark": "github-dark"
      }
    },
    "anchors": "buttons",
    "rounded": "default",
    "icons": {
      "library": "lucide"
    }
  },

  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },

  "appearance": {
    "default": "dark",
    "strict": true
  },

  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#FFFFFF",
      "dark": "#000000"
    }
  },

  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Takumo Cloud",
      "href": "https://cloud.takumo.io/dashboard"
    }
  },

  "anchors": [
    {
      "anchor": "Takumo Cloud",
      "icon": "server",
      "href": "https://cloud.takumo.io/dashboard"
    },
    {
      "anchor": "GitHub",
      "icon": "github",
      "href": "https://github.com/SirTingling/takumo"
    }
  ],

