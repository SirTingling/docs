{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Takumo",
  "description": "Bidirectional AI code governance. Protect secrets going out, validate code coming in.",

  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },

  "logo": {
    "light": "/logo/takumo-dark.svg",
    "dark": "/logo/takumo-light.svg",
    "href": "/"
  },

  "favicon": "/logo/favicon.svg",

  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system",
    "anchors": "sections",
    "rounded": "default",
    "icons": {
      "library": "lucide"
    }
  },

  "fonts": {
    "heading": {
      "family": "Geist Sans",
      "source": "https://cdn.vercel.com/fonts/geist-sans/Geist-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "Geist Sans",
      "source": "https://cdn.vercel.com/fonts/geist-sans/Geist-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },

  "appearance": {
    "default": "dark",
    "strict": false
  },

  "background": {
    "decoration": "gradient"
  },

  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "/changelog"
      },
      {
        "label": "takumo.io",
        "href": "https://takumo.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Dashboard",
      "href": "https://cloud.takumo.io/dashboard"
    }
  },

  "anchors": [
    {
      "anchor": "Dashboard",
      "icon": "layout-dashboard",
      "href": "https://cloud.takumo.io/dashboard"
    },
    {
      "anchor": "GitHub",
      "icon": "github",
      "href": "https://github.com/SirTingling/takumo"
    }
  ],

  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "quickstart",
              "installation",
              "authentication",
              "first-request"
            ]
          },
          {
            "group": "Concepts",
            "icon": "lightbulb",
            "pages": [
              "concepts/how-it-works",
              "concepts/aegis-shield",
              "concepts/sentinel",
              "concepts/security",
              "concepts/policies"
            ]
          },
          {
            "group": "Reference",
            "icon": "bookmark",
            "pages": [
              "patterns/supported",
              "reference/plan-comparison",
              "reference/error-codes",
              "reference/faq",
              "reference/troubleshooting",
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "Dashboard",
        "icon": "layout-dashboard",
        "groups": [
          {
            "group": "Guide",
            "icon": "book-open",
            "pages": [
              "dashboard/overview",
              "dashboard/api-keys",
              "dashboard/fleet",
              "dashboard/members",
              "dashboard/audit-log",
              "dashboard/security",
              "dashboard/billing",
              "dashboard/settings"
            ]
          }
        ]
      },
      {
        "tab": "Deployment",
        "icon": "cloud",
        "groups": [
          {
            "group": "Guides",
            "icon": "server",
            "pages": [
              "deployment/overview",
              "deployment/saas",
              "deployment/onprem",
              "deployment/configuration",
              "deployment/monitoring"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "icon": "terminal",
        "groups": [
          {
            "group": "Commands",
            "pages": [
              "cli/overview",
              "cli/scan",
              "cli/tokenize",
              "cli/shield"
            ]
          }
        ]
      },
      {
        "tab": "AI Tools",
        "icon": "blocks",
        "groups": [
          {
            "group": "Integrations",
            "pages": [
              "ai-tools/overview",
              "ai-tools/cursor",
              "ai-tools/copilot",
              "ai-tools/continue",
              "ai-tools/windsurf",
              "ai-tools/claude-code",
              "ai-tools/generic"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "icon": "code",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "api/overview",
              "api/authentication",
              "api/create-session",
              "api/tokenize",
              "api/rehydrate",
              "api/errors",
              "api/rate-limits",
              "api/webhooks"
            ]
          }
        ]
      }
    ]
  },

  "footer": {
    "socials": {
      "github": "https://github.com/SirTingling/takumo"
    }
  },

  "search": {
    "prompt": "Search docs..."
  },

  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "cursor"]
  }
}
